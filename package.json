{
  "name": "open-alttester-server",
  "version": "0.3.0",
  "description": "Open-source AltTester Desktop replacement — WebSocket server and web dashboard for Bun and Node.js",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "alttester",
    "unity",
    "testing",
    "websocket",
    "bun",
    "node",
    "cli",
    "game-testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/PMelch/open-alttester-server.git"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=20.0.0"
  },
  "bin": {
    "open-alttester-server": "./bin/open-alttester-server.js"
  },
  "readme": "README.npm.md",
  "files": [
    "README.npm.md",
    "CHANGELOG.md",
    "src/index.ts",
    "src/cli.ts",
    "src/server/adapter.ts",
    "src/server/adapters/",
    "src/server/inspector.ts",
    "src/server/registry.ts",
    "src/server/server.ts",
    "src/web/dashboard.html",
    "src/web/handler.ts",
    "src/web/inspector-handler.ts",
    "bin/"
  ],
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "tsx src/index.ts",
    "start:bun": "bun src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:bun": "bun test",
    "test:bun:watch": "bun test --watch",
    "test:bun:coverage": "bun test --coverage",
    "typecheck": "tsc --project tsconfig.node.json --noEmit",
    "typecheck:bun": "tsc --project tsconfig.bun.json --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "tsx": "^4.0.0",
    "ws": "^8.20.0"
  }
}
