{
  "name": "open-alttester-server",
  "version": "0.1.0",
  "description": "Open-source AltTester Desktop replacement — Bun-based WebSocket server and web dashboard",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "vue": "^3.5.32"
  }
}
